{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "pretool-agent"
            ],
            "timeout": 10,
            "statusMessage": "Checking subagent budget"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "pretool-agent"
            ],
            "timeout": 10,
            "statusMessage": "Checking subagent budget"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "posttool-agent"
            ],
            "timeout": 10,
            "statusMessage": "Recording subagent usage"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "posttool-agent"
            ],
            "timeout": 10,
            "statusMessage": "Recording subagent usage"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "posttool-batch"
            ],
            "timeout": 10,
            "statusMessage": "Checking queued subagents"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "subagent-start"
            ],
            "timeout": 10,
            "statusMessage": "Recording subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "subagent-stop"
            ],
            "timeout": 10,
            "statusMessage": "Recording subagent stop"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "task-created"
            ],
            "timeout": 10,
            "statusMessage": "Checking agent-team budget"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "task-completed"
            ],
            "timeout": 10,
            "statusMessage": "Recording agent-team completion"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/bin/hook.js",
              "user-prompt-submit"
            ],
            "timeout": 10,
            "statusMessage": "Checking 5-hour budget"
          }
        ]
      }
    ]
  }
}
